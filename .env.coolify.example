# Core app
ENVIRONMENT=production
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@postgres:5432/seomachine
REDIS_URL=redis://redis:6379/0
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
SETTINGS_ENCRYPTION_KEY=CHANGE_ME_32_PLUS_CHARS
BACKEND_CORS_ORIGINS=https://seo.yourdomain.com

# Frontend
NEXT_PUBLIC_API_BASE=https://seo-api.yourdomain.com/api/v1

# Google Analytics 4 / Search Console
GA4_PROPERTY_ID=123456789
GA4_CREDENTIALS_PATH=/run/secrets/ga4-credentials.json
GSC_SITE_URL=sc-domain:yourdomain.com
GSC_CREDENTIALS_PATH=/run/secrets/gsc-credentials.json

# DataForSEO
DATAFORSEO_LOGIN=your_email@example.com
DATAFORSEO_PASSWORD=your_dataforseo_password
DATAFORSEO_LOCATION_CODE=2682
DATAFORSEO_LANGUAGE_CODE=ar
DATAFORSEO_LANGUAGE_NAME=Arabic
DATAFORSEO_DEVICE=desktop
DATAFORSEO_OS=windows

# Optional content filters
BLOG_PATH=/blog/
